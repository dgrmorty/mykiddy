{
  "name": "kiddy-os",
  "version": "1.0.0",
  "description": "Kiddy Campus: IT Future School Platform",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "tsc",
    "start": "node server.js",
    "preview": "vite preview",
    "server": "node server.js",
    "android:init": "npm install @capacitor/android && npx cap add android",
    "android:build": "npm run build && npx cap sync && npx cap open android",
    "apk": "npm run build && npx cap sync android && chmod +x android/gradlew && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
