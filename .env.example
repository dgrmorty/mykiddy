# ============== Клиент (Vite, сборка фронта) ==============
# Задаются при сборке: npm run build или в Railway/Vercel.

# URL бэкенда (API). В продакшене — ваш домен, например https://mykiddy-production.up.railway.app
# Если не задано, используется текущий origin (SPA и API на одном домене).
VITE_API_URL=mykiddy-production.up.railway.app

# Supabase (для клиента используется anon key — это нормально для RLS).
