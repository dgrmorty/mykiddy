# ============== Клиент (Vite, сборка фронта) ==============
# Задаются при сборке: npm run build или в Railway/Vercel.

# URL бэкенда (API). В продакшене — ваш домен, например https://mykiddy-production.up.railway.app
# Если не задано, используется текущий origin (SPA и API на одном домене).
VITE_API_URL=

# Supabase (для клиента используется anon key — это нормально для RLS).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Список email админов через запятую. В продакшене обязательно задать!
# Без этой переменной в коде нет fallback — админов не будет.
VITE_ADMIN_EMAILS=admin@example.com

# ============== Сервер (Node, server.js) ==============
# Задаются в Railway / Heroku / .env при запуске node server.js

PORT=3000

# Ключ Google Gemini API (обязательно для ИИ-тьютора и проверки ДЗ).
API_KEY=your-gemini-api-key

# Supabase для сервера (проверка JWT, запись ai_usage).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Лимиты ИИ в день на пользователя (опционально).
# AI_DAILY_TUTOR_LIMIT=25
# AI_DAILY_HOMEWORK_LIMIT=15

# Дополнительные CORS origins через запятую (если деплой на свой домен).
# CORS_ORIGIN=https://mykiddy.ru,https://app.mykiddy.ru
