{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build",
    "watchPatterns": ["package.json", "package-lock.json", "vite.config.ts", "tsconfig.json", "index.html", "src/**", "views/**", "components/**", "contexts/**", "services/**", "config.ts", "App.tsx"]
  },
  "deploy": {
    "startCommand": "npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
